<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base window theme. All real colors come from the Compose color scheme, so
      this only sets up transparent system bars for edge-to-edge.
    -->
    <style name="Theme.Spectra" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
